# Ride Relax environment template
# Copy this file to .env.local for local development.
# Add the same values in Vercel Project Settings > Environment Variables.

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Ride Relax

# Clerk Auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/user-login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/user-login
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/user-dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/user-dashboard

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# Storage
NEXT_PUBLIC_STORAGE_PROVIDER=supabase
NEXT_PUBLIC_RIDER_PHOTOS_BUCKET=rr-rider-photos
NEXT_PUBLIC_MOTORCYCLE_PHOTOS_BUCKET=rr-motorcycle-photos
NEXT_PUBLIC_DOCUMENTS_BUCKET=rr-private-documents

# Mapbox
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=

# Stripe - later milestone
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Internal jobs - later milestone
DOCUMENT_EXPIRATION_WARNING_DAYS=30
